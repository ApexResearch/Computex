# Computex Environment Configuration
# Copy this to .env and fill in appropriate values

# Environment
COMPUTEX_ENV=development

# Server Configuration
COMPUTEX_HOST=0.0.0.0
COMPUTEX_PORT=8080

# Database
DATABASE_URL=postgres://computex_user:changeme@localhost:5432/computex
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=5

# Redis (for caching and session management)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# 2FA Configuration
ENABLE_2FA=true

# Quantum Cryptography
ENABLE_QUANTUM_CRYPTO=true
ENCRYPTION_ALGORITHM=ChaCha20-Poly1305

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Market Configuration
MIN_ORDER_AMOUNT=0.001
MAX_ORDER_AMOUNT=1000000.0
ORDER_TIMEOUT_SECONDS=3600
ENABLE_FUTURES_MARKET=true

# Optional: TLS/SSL (for production)
# TLS_CERT_PATH=/etc/computex/certs/server.crt
# TLS_KEY_PATH=/etc/computex/certs/server.key

# Optional: Monitoring
# PROMETHEUS_ENABLED=true
# METRICS_PORT=9090
